{
  "name": "isy",
  "version": "0.0.0",
  "private": true,
  "description": "ISY — end-to-end encrypted messenger with UIN identity",
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "pnpm --filter @isy/web dev",
    "dev:desktop": "echo 'apps/desktop not scaffolded yet' && exit 1",
    "dev:mobile": "echo 'apps/mobile not scaffolded yet' && exit 1",
    "build": "pnpm --filter @isy/web build",
    "build:desktop": "echo 'apps/desktop not scaffolded yet' && exit 1",
    "build:apk": "echo 'apps/mobile not scaffolded yet' && exit 1",
    "typecheck": "pnpm -r typecheck",
    "test": "vitest run",
    "test:watch": "vitest",
    "e2e": "echo 'playwright not configured yet' && exit 0",
    "convex:dev": "convex dev",
    "convex:deploy": "convex deploy",
    "convex:codegen": "convex codegen"
  },
  "devDependencies": {
    "@edge-runtime/vm": "^5.0.0",
    "convex": "^1.35.1",
    "convex-test": "^0.0.49",
    "vitest": "^2"
  }
}
